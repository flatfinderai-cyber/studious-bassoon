# Copy this file to agent/.env and fill in your values.
# agent/.env is gitignored — never commit real credentials.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token — needs: repo (read + write + pull requests)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# ── Managed Agent IDs (filled in by setup.py) ─────────────────────────────────
FLATFINDER_AGENT_ID=agent_...
FLATFINDER_ENVIRONMENT_ID=env_...
